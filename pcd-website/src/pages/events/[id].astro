---
import { getCollection } from 'astro:content';
import { loadNodes } from '../../lib/nodes';
import '../../styles/global.css';
import { formatDateRange, formatTimeRange, onlinePlatformName } from '../../lib/format';

export async function getStaticPaths() {
  const entries = await getCollection('events');
  return entries.map((entry) => ({
    params: { id: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const nodes = await loadNodes();
const node = nodes.find((candidate) => candidate.id === entry.data.id);

if (!node) {
  throw new Error(`Missing node data for event page "${entry.data.id}".`);
}

const { Content } = await entry.render();
const eventDate = node.date_tbd
  ? 'Date TBD'
  : formatDateRange(node.event_date ?? '', node.event_end_date);
const eventTime = !node.date_tbd && node.event_start_time
  ? formatTimeRange(node.event_start_time, node.event_end_time)
  : node.time_tbd
    ? 'Time TBD'
    : '';
const locationLabel = node.online_event
  ? onlinePlatformName(node.event_url)
  : node.location_tbd
    ? 'Location TBD'
    : node.address;
const locationDetail = node.online_event
  ? node.event_url
  : node.location_tbd
    ? ''
    : node.address;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{node.event_name} | Processing Community Day 2026</title>
    <meta name="description" content={node.event_short_description || `${node.event_name} event details`} />
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
  </head>
  <body class="event-page-body">
    <main class="event-page">
      <div class="event-page-topbar">
        <a class="event-page-back" href={`${import.meta.env.BASE_URL}/?event=${node.id}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/></svg>
          Back to map
        </a>
        <a class="event-page-submit-btn" href="https://github.com/SableRaf/pcd-website-mvp-2/issues/new?template=new-event.yml" target="_blank" rel="noopener noreferrer">
          Submit an event
        </a>
      </div>
      <article class="event-page-card">
        <header class="event-page-header">
          <div class="event-page-kicker-row">
            <p class="event-page-kicker">Processing Community Day 2026</p>
            <div class="event-page-share-wrap">
              <button
                id="event-page-share-btn"
                class="event-page-share-btn"
                aria-label="Share event"
                aria-controls="event-page-share-menu"
                aria-expanded="false"
                title="Share event"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" aria-hidden="true"><g fill="currentColor" fill-rule="evenodd"><path d="M3.5 6a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5h-2a.5.5 0 0 1 0-1h2A1.5 1.5 0 0 1 14 6.5v8a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 14.5v-8A1.5 1.5 0 0 1 3.5 5h2a.5.5 0 0 1 0 1z"/><path d="M7.646.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 1.707V10.5a.5.5 0 0 1-1 0V1.707L5.354 3.854a.5.5 0 1 1-.708-.708z"/></g></svg>
              </button>
              <div id="event-page-share-menu" class="event-page-share-menu" role="menu" hidden>
                <button id="event-page-copy-link" role="menuitem">Copy link</button>
                <a id="event-page-mastodon" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">Share on Mastodon</a>
                <a id="event-page-bluesky" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">Share on Bluesky</a>
                <a id="event-page-facebook" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">Share on Facebook</a>
                <a id="event-page-linkedin" href="#" target="_blank" rel="noopener noreferrer" role="menuitem">Share on LinkedIn</a>
              </div>
            </div>
          </div>
          <h1>{node.event_name}</h1>
          {node.organization_name && <p class="event-page-entity">by {node.organization_name}</p>}
          {node.event_short_description && <p class="event-page-summary">{node.event_short_description}</p>}
        </header>

        <section class="event-page-meta" aria-label="Event details">
          <div>
            <span class="event-page-meta-label">When</span>
            <strong>{eventDate}</strong>
            {eventTime && <span>{eventTime}</span>}
          </div>
          <div>
            <span class="event-page-meta-label">Where</span>
            <strong>{locationLabel}</strong>
            {locationDetail && <span>{locationDetail}</span>}
          </div>
          <div>
            <span class="event-page-meta-label">Contact</span>
            <a href={`mailto:${node.primary_contact.email}`}>{node.primary_contact.email}</a>
            {node.event_website && (
              <a href={node.event_website} target="_blank" rel="noopener noreferrer">
                Visit event website
              </a>
            )}
          </div>
        </section>

        <section class="event-page-content">
          <Content />
        </section>
      </article>
    </main>
    <script>
      const shareBtn = document.getElementById('event-page-share-btn')!;
      const shareMenu = document.getElementById('event-page-share-menu')!;
      const copyBtn = document.getElementById('event-page-copy-link')!;
      const shareMenuActions = shareMenu.querySelectorAll('a, button');
      const url = window.location.href;
      const title = document.title.split(' | ')[0];

      const setShareMenuOpen = (open: boolean) => {
        shareMenu.hidden = !open;
        shareBtn.setAttribute('aria-expanded', String(open));
      };

      document.getElementById('event-page-mastodon')!.setAttribute('href',
        `https://mastodon.social/share?text=${encodeURIComponent(title + ' ' + url)}`);
      document.getElementById('event-page-bluesky')!.setAttribute('href',
        `https://bsky.app/intent/compose?text=${encodeURIComponent(title + ' ' + url)}`);
      document.getElementById('event-page-facebook')!.setAttribute('href',
        `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`);
      document.getElementById('event-page-linkedin')!.setAttribute('href',
        `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`);

      shareBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        setShareMenuOpen(shareMenu.hidden);
      });

      copyBtn.addEventListener('click', async () => {
        try { await navigator.clipboard.writeText(url); } catch {}
        shareBtn.setAttribute('aria-label', 'Link copied!');
        shareBtn.title = 'Link copied!';
        setShareMenuOpen(false);
        setTimeout(() => {
          shareBtn.setAttribute('aria-label', 'Share event');
          shareBtn.title = 'Share event';
        }, 2000);
      });

      shareMenuActions.forEach((action) => {
        if (action !== copyBtn) {
          action.addEventListener('click', () => setShareMenuOpen(false));
        }
      });

      document.addEventListener('click', (e) => {
        if (!(e.target as HTMLElement).closest('.event-page-share-wrap')) {
          setShareMenuOpen(false);
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          setShareMenuOpen(false);
        }
      });
    </script>
  </body>
</html>
